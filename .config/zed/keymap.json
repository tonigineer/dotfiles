// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  // ——— Leader Keys —————————————————————————————————————————————————————————————
  {
    "context": "VimControl && !menu && vim_mode != insert",
    "bindings": {
      "space": null,
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
      "space d": "editor::GoToDefinition",
      "space v": "editor::GoToDefinitionSplit",
      "space i": "editor::FindAllReferences",
      "space t": "editor::GoToTypeDefinition",
      "space r": "editor::Rename",
      "space a": "editor::ToggleCodeActions",
      "space f": "editor::Format",
      "space h": "editor::Hover",
      "space D": "diagnostics::Deploy",
      "space l s": "outline::Toggle",
      "space s f": "file_finder::Toggle",
      "space s g": "pane::DeploySearch",
      "space space": "tab_switcher::Toggle",
      "space 1": "editor::FoldAtLevel_1",
      "space 2": "editor::FoldAtLevel_2",
      "space 0": "editor::UnfoldAll",
    },
  },

  // ——— Insert Mode —————————————————————————————————————————————————————————————
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
    },
  },

  // ——— Editor Shortcuts ————————————————————————————————————————————————————————
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-a": "editor::SelectAll",
      "ctrl-c": "editor::Copy",
      "ctrl-x": "editor::Cut",
      "ctrl-v": "editor::Paste",
      "ctrl-z": "editor::Undo",
      "ctrl-y": "editor::Redo",
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-s": "workspace::Save",
      "ctrl-k ctrl-j": "editor::UnfoldAll",
    },
  },

  // ——— Terminal ————————————————————————————————————————————————————————————————
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-c": "terminal::Copy",
      "ctrl-v": "terminal::Paste",
    },
  },

  // ——— Docks & Panels ——————————————————————————————————————————————————————————
  // No "context" → always active, regardless of focus.
  {
    "bindings": {
      "alt-`": "terminal_panel::ToggleFocus",
      "alt-0": "workspace::ToggleRightDock",
      "alt-1": "project_panel::ToggleFocus",
      "alt-2": "git_panel::ToggleFocus",
    },
  },
  // vim-specific tweak stays scoped:
  {
    "context": "vim_mode == normal && (Editor || Dock)",
    "bindings": {
      "space": null,
    },
  },

  // ——— Overrides ———————————————————————————————————————————————————————————————
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-k ctrl-s": "zed::OpenKeymap",
    },
    "bindings": {
      "ctrl-j": null,
      "ctrl-n": null,
    },
  },
  {
    "context": "((FileFinder || FileFinder > Picker > Editor) || FileFinder > Picker > menu)",
    "bindings": {
      "ctrl-j": null,
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-k ctrl-i": null,
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-n": null,
    },
  },
  {
    "context": "KeymapEditor",
    "unbind": {
      "ctrl-k": "keymap_editor::OpenCreateKeybindingModal",
      "ctrl-e": "zed::OpenKeymapFile",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "g f": "editor::OpenSelectedFilename",
    },
  },

  // ——— Project Panel ———————————————————————————————————————————————————————————
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-k ctrl-2": "editor::FoldAtLevel_2",
    },
  },
]
